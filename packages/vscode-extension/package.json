{
  "name": "vscode-webgal",
  "displayName": "WebGAL Language Support (Dev)",
  "description": "Language server for WebGAL scenario files (development only)",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "webgal",
        "aliases": ["WebGAL", "webgal"],
        "extensions": [".txt"],
        "filenamePatterns": ["**/scene/**/*.txt"],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "WebGAL Language Server",
      "properties": {
        "webgal-ls.trace.server": {
          "type": "string",
          "scope": "window",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc",
    "watch": "tsc --watch",
    "build": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "vscode-languageclient": "^10.0.0"
  }
}