{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build:rust",
      "type": "shell",
      "command": "cargo",
      "args": ["build", "-p", "webgal-ls"],
      "options": {
        "cwd": "${workspaceFolder}/../.."
      },
      "group": "build",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "build:extension",
      "type": "shell",
      "command": "npm",
      "args": ["run", "compile"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "build:all",
      "dependsOn": ["build:rust", "build:extension"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}