{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Playground WASM",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build:wasm"],
      "cwd": "${workspaceFolder}/packages/parse-playground",
      "problemMatcher": []
    },
    {
      "label": "Start Playground Server",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev", "--", "--host", "0.0.0.0"],
      "cwd": "${workspaceFolder}/packages/parse-playground",
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "vite",
          "pattern": {
            "regexp": "^.*(Local:|ready in).*$",
            "file": 1,
            "location": 2,
            "message": 0
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": ".*(Local:|ready in).*$"
          }
        }
      ]
    }
  ]
}
