{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Playground",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/packages/parse-playground",
      "preLaunchTask": "Start Playground Server",
      "runtimeArgs": ["--disable-web-security"],
      "sourceMapPathOverrides": {
        "webpack:///./*": "${webRoot}/*"
      }
    }
  ]
}
