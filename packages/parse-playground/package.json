{
  "name": "webgal-parse-playground",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:wasm": "cd ../../crates/webgal-language-service && wasm-pack build --target web --release",
    "build:wasm:dev": "cd ../../crates/webgal-language-service && wasm-pack build --target web",
    "dev": "vite",
    "build": "npm run build:wasm && tsc && vite build",
    "build:dev": "npm run build:wasm:dev && tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "webgal-language-service": "file:../../crates/webgal-language-service/pkg"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "monaco-editor": "^0.34.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}